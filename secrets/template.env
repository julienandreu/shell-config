# secrets/template.env
# Copy this file to ~/.config/dotfiles/secrets.env (chmod 600).
# It is sourced by configs/zsh/init.zsh at the end of shell startup.
# This file should NOT be committed to git.

# Git identity is handled separately by setup.sh, which writes
# ~/.config/dotfiles/git.local (referenced by configs/git/config).
# These exports are only useful if some tool reads them directly.
export GIT_USER_NAME="Your Name"
export GIT_USER_EMAIL="your.email@example.com"

# GitHub
# Run: gh auth login (will be prompted on first setup)

# AWS
export AWS_PROFILE="default"
export AWS_REGION="us-east-1"
# Run: aws configure sso (will be prompted on first setup)

